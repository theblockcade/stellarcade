# General
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellarcade
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stellarcade

# Redis
REDIS_URL=redis://localhost:6379

# Stellar Network
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_REQUEST_TIMEOUT=30000
STELLAR_MAX_RETRIES=3
STELLAR_RETRY_INTERVAL=1000

# Contract IDs (Placeholders)
PRIZE_POOL_CONTRACT_ID=C...
RNG_CONTRACT_ID=C...
COIN_FLIP_CONTRACT_ID=C...

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_me

# Startup validation notes:
# - `JWT_SECRET` is always required.
# - Use either `DATABASE_URL` OR all of DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
# - `PORT` and `DB_PORT` must be positive integers when provided.
# - `STELLAR_NETWORK` must be one of: test, testnet, public, mainnet, futurenet, sandbox, standalone.
# - `HORIZON_URL` must start with http:// or https://.

# Logging
LOG_LEVEL=info
