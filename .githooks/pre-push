#!/bin/bash
# Pre-Push Hook for Stellarcade
# Runs strict checks only on touched contract crates and validates doc sync.
# Enable this hook: git config core.hooksPath .githooks
set -euo pipefail

ALL_CONTRACT_CRATES=(
    "access-control"
    "balance-management"
    "coin-flip"
    "emergency-pause"
    "higher-lower"
    "prize-pool"
    "random-generator"
    "shared"
    "trivia-game"
)

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAIL=0

echo "🚀 Running pre-push verification..."

# ── Collect changed files across all pushed refs ─────────────────────────────
CHANGED_FILES=""
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        BASE=$(git merge-base HEAD main 2>/dev/null || echo "")
        RANGE="${BASE:+$BASE..}$local_sha"
    else
        RANGE="$remote_sha..$local_sha"
    fi
    CHANGED_FILES="$CHANGED_FILES$(git diff --name-only "$RANGE" 2>/dev/null)"$'\n'
done

# ── Determine which contract crates were touched ──────────────────────────────
TOUCHED_CRATES=()
for crate in "${ALL_CONTRACT_CRATES[@]}"; do
    if echo "$CHANGED_FILES" | grep -q "^contracts/$crate/"; then
        TOUCHED_CRATES+=("$crate")
    fi
done

# ── 1. Strict Rust checks (fmt + clippy + test) for each touched crate ────────
if command -v cargo >/dev/null 2>&1; then
    if [ ${#TOUCHED_CRATES[@]} -gt 0 ]; then
        echo "🦀 Strict Rust checks on: ${TOUCHED_CRATES[*]}"
        for crate in "${TOUCHED_CRATES[@]}"; do
            CRATE_DIR="$REPO_ROOT/contracts/$crate"
            echo "   ▶ $crate: fmt"
            if ! (cd "$CRATE_DIR" && cargo fmt --all -- --check 2>&1); then
                echo "❌ fmt failed in $crate."
                echo "   Fix: cd contracts/$crate && cargo fmt --all"
                FAIL=1
            fi
            echo "   ▶ $crate: clippy"
            if ! (cd "$CRATE_DIR" && cargo clippy --all-targets --all-features -- -D warnings 2>&1); then
                echo "❌ clippy failed in $crate. Resolve all warnings before pushing."
                FAIL=1
            fi
            echo "   ▶ $crate: test"
            if ! (cd "$CRATE_DIR" && cargo test 2>&1); then
                echo "❌ Tests failed in $crate."
                echo "   Fix: cd contracts/$crate && cargo test"
                FAIL=1
            fi
        done
    else
        echo "ℹ️  No contract crates changed — skipping Rust checks."
    fi
else
    echo "⚠️  Cargo not found. Install Rust: https://rustup.rs"
fi

# ── 2. Contract doc sync check ────────────────────────────────────────────────
CONTRACTS_DOCS_CHANGED=$(echo "$CHANGED_FILES" | grep -E "^contracts/|^docs/contracts/" || true)
if [ -n "$CONTRACTS_DOCS_CHANGED" ]; then
    echo "📄 Checking contract doc sync..."
    CONTRACTS_README="$REPO_ROOT/contracts/README.md"
    SYNC_FAIL=0
    for crate in "${ALL_CONTRACT_CRATES[@]}"; do
        if ! grep -q "$crate" "$CONTRACTS_README"; then
            echo "❌ Doc sync: '$crate' missing from contracts/README.md"
            echo "   Fix: add an entry for '$crate' in contracts/README.md"
            SYNC_FAIL=1
        fi
    done
    [ $SYNC_FAIL -eq 0 ] && echo "✅ Contract doc sync OK."
    FAIL=$((FAIL + SYNC_FAIL))
fi

# ── 3. Backend tests (only when backend/ files changed) ───────────────────────
BACKEND_CHANGED=$(echo "$CHANGED_FILES" | grep "^backend/" || true)
if [ -n "$BACKEND_CHANGED" ]; then
    echo "📦 Verifying backend..."
    if command -v npm >/dev/null 2>&1; then
        if ! (cd "$REPO_ROOT/backend" && npm test 2>&1); then
            echo "❌ Backend tests failed."
            echo "   Fix: cd backend && npm test"
            FAIL=1
        fi
    else
        echo "⚠️  NPM not found. Install Node.js: https://nodejs.org"
    fi
fi

# ── Result ────────────────────────────────────────────────────────────────────
if [ $FAIL -ne 0 ]; then
    echo ""
    echo "🚫 Pre-push checks FAILED — push aborted."
    exit 1
fi

echo "✨ All checks passed! Proceeding with push."
